# ---- Pinecone (vector store, integrated inference) ----
PINECONE_API_KEY=
# Index is auto-created on first run if missing.
PINECONE_INDEX=bettersearch
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
PINECONE_EMBED_MODEL=llama-text-embed-v2
PINECONE_RERANK_MODEL=bge-reranker-v2-m3

# ---- OpenRouter (vision OCR + RAG synthesis) ----
OPENROUTER_API_KEY=
# Both defaults are verified to have Zero-Data-Retention providers on OpenRouter.
# Vision (OCR) stays strong; chat synthesis is dirt-cheap (~$0.18/M output).
OPENROUTER_VISION_MODEL=google/gemini-2.5-flash
OPENROUTER_CHAT_MODEL=deepseek/deepseek-v4-flash
# Only route to ZDR + non-data-collecting providers. Leave true for a ZDR policy.
BS_ZDR_ONLY=true

# ---- Access control ----
# Shared bearer secret. The plugin, the web UI, and Hermes all present this.
# Generate one, e.g.:  openssl rand -hex 24
BS_API_TOKEN=

# ---- Server ----
PORT=8787

# ---- Ingestion tuning (optional) ----
BS_CHUNK_CHARS=1200
BS_CHUNK_OVERLAP=150
BS_MAX_ATTACHMENT_BYTES=20971520

# ---- Search tuning (optional) ----
# Rerank-score floor for the "related" matches shown alongside cited sources.
BS_MIN_SCORE=0.05
